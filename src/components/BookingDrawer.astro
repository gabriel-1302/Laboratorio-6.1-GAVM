---
---

<!-- Backdrop overlay -->
<div id="booking-backdrop" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 opacity-0 pointer-events-none transition-opacity duration-500"></div>

<!-- Slide-out drawer -->
<div id="booking-drawer" class="fixed top-0 right-0 h-screen w-full sm:w-[450px] bg-zinc-950 border-l border-zinc-900 z-50 translate-x-full transition-transform duration-500 flex flex-col justify-between p-8 md:p-12 overflow-y-auto">
  <div>
    <!-- Header -->
    <div class="flex justify-between items-center mb-12">
      <h2 class="font-['Cormorant_Garamond'] text-2xl tracking-widest text-white uppercase">Reservar Espacio</h2>
      <button id="close-drawer" class="text-zinc-500 hover:text-white transition-colors duration-300 text-xs uppercase tracking-[0.2em] flex items-center gap-2">
        <span>Cerrar</span>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Booking Form -->
    <form id="booking-form" class="space-y-8">
      <div>
        <label class="block text-[10px] uppercase tracking-[0.2em] text-zinc-500 mb-2">Seleccionar Habitación</label>
        <select required id="booking-suite" class="w-full bg-zinc-900 border border-zinc-800 focus:border-zinc-500 text-white rounded-none p-4 text-xs tracking-wider uppercase outline-none transition-colors duration-300">
          <option value="sombra">Suite Sombra Lumínica</option>
          <option value="vacio">Suite Vacío Puro</option>
        </select>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-[10px] uppercase tracking-[0.2em] text-zinc-500 mb-2">Llegada</label>
          <input required type="date" id="booking-arrival" class="w-full bg-zinc-900 border border-zinc-800 focus:border-zinc-500 text-white rounded-none p-4 text-xs tracking-wider outline-none transition-colors duration-300" />
        </div>
        <div>
          <label class="block text-[10px] uppercase tracking-[0.2em] text-zinc-500 mb-2">Salida</label>
          <input required type="date" id="booking-departure" class="w-full bg-zinc-900 border border-zinc-800 focus:border-zinc-500 text-white rounded-none p-4 text-xs tracking-wider outline-none transition-colors duration-300" />
        </div>
      </div>

      <div>
        <label class="block text-[10px] uppercase tracking-[0.2em] text-zinc-500 mb-2">Nombre Completo</label>
        <input required type="text" id="booking-name" placeholder="Escribe tu nombre..." class="w-full bg-zinc-900 border border-zinc-800 focus:border-zinc-500 text-white rounded-none p-4 text-xs tracking-wider outline-none transition-colors duration-300 placeholder-zinc-700" />
      </div>

      <div>
        <label class="block text-[10px] uppercase tracking-[0.2em] text-zinc-500 mb-2">Correo Electrónico</label>
        <input required type="email" id="booking-email" placeholder="email@ejemplo.com" class="w-full bg-zinc-900 border border-zinc-800 focus:border-zinc-500 text-white rounded-none p-4 text-xs tracking-wider outline-none transition-colors duration-300 placeholder-zinc-700" />
      </div>

      <button type="submit" class="w-full border border-white/20 hover:border-white text-white uppercase text-[10px] tracking-[0.3em] py-5 transition-all duration-500 bg-transparent hover:bg-white hover:text-black font-semibold">
        Confirmar Solicitud de Reserva
      </button>
    </form>

    <!-- Success Message -->
    <div id="booking-success" class="hidden text-center py-12 space-y-6">
      <div class="w-12 h-12 rounded-full border border-zinc-800 flex items-center justify-center mx-auto text-emerald-500">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
        </svg>
      </div>
      <h3 class="font-['Cormorant_Garamond'] text-2xl tracking-widest text-white uppercase">Petición Recibida</h3>
      <p class="text-xs text-zinc-400 leading-relaxed max-w-xs mx-auto">
        Hemos establecido conexión con el satélite. Tu solicitud para la <span id="confirmed-suite" class="text-white font-medium"></span> ha sido registrada.
      </p>
      <div class="bg-zinc-900 border border-zinc-800 p-4 font-mono text-[10px] tracking-[0.2em] text-zinc-300 max-w-xs mx-auto">
        CÓDIGO: <span id="booking-code" class="text-white font-bold"></span>
      </div>
      <p class="text-[9px] text-zinc-500 uppercase tracking-widest">Un agente de Monolith se pondrá en contacto en un plazo de 24 horas.</p>
    </div>
  </div>

  <div class="pt-8 border-t border-zinc-900/50 text-[9px] text-zinc-600 tracking-[0.2em] uppercase">
    Monolith © Solicitud de Estadía
  </div>
</div>

<script>
  const openButtons = document.querySelectorAll('.open-booking');
  const closeButton = document.getElementById('close-drawer');
  const backdrop = document.getElementById('booking-backdrop');
  const drawer = document.getElementById('booking-drawer');
  const form = document.getElementById('booking-form') as HTMLFormElement;
  const successContainer = document.getElementById('booking-success');
  const confirmedSuiteSpan = document.getElementById('confirmed-suite');
  const bookingCodeSpan = document.getElementById('booking-code');

  function openDrawer() {
    if (drawer && backdrop) {
      drawer.classList.remove('translate-x-full');
      backdrop.classList.remove('opacity-0', 'pointer-events-none');
    }
  }

  function closeDrawer() {
    if (drawer && backdrop) {
      drawer.classList.add('translate-x-full');
      backdrop.classList.add('opacity-0', 'pointer-events-none');
      // Reset form and screen state after drawer closes
      setTimeout(() => {
        if (form && successContainer) {
          form.classList.remove('hidden');
          successContainer.classList.add('hidden');
          form.reset();
        }
      }, 500);
    }
  }

  openButtons.forEach(btn => btn.addEventListener('click', openDrawer));
  closeButton?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    const suiteSelect = document.getElementById('booking-suite') as HTMLSelectElement;
    const suiteName = suiteSelect.options[suiteSelect.selectedIndex].text;
    const randomCode = 'MNLT-' + Math.floor(1000 + Math.random() * 9000);

    if (confirmedSuiteSpan) confirmedSuiteSpan.textContent = suiteName;
    if (bookingCodeSpan) bookingCodeSpan.textContent = randomCode;

    form.classList.add('hidden');
    successContainer?.classList.remove('hidden');
  });

  // Export event listener trigger for external scripts
  window.addEventListener('open-booking-drawer', openDrawer);
</script>
